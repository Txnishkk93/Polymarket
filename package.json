{
  "name": "polymarket",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.17",
    "typescript": "5.9.2"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.1",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supabase": "^2.105.0"
  }
}
